# Gemini API key (replaces OpenAI) — get yours at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Image generation — choose ONE of the following:

# Option 1 (FREE): Hugging Face Inference API — https://huggingface.co/settings/tokens
# Uses FLUX.1-schnell on the free tier. No credit card required.
HF_TOKEN=your_huggingface_token_here

# Option 2 (Paid): Replicate API key — https://replicate.com/
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Option 3 (Paid): FAL AI API key — https://fal.ai/
FAL_KEY=your_fal_api_key_here
